{
  "manifest_version": 3,
  "name": "hypergravity",
  "version": "1.0",
  "description": "Enhance the Gemini web interface",
  "content_scripts": [
    {
      "js": [
        "assets/content.jsx-Pnj3N97b.js"
      ],
      "matches": [
        "*://gemini.google.com/*"
      ],
      "css": [
        "assets/content-lHdOApwb.css"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://gemini.google.com/*"
      ],
      "resources": [
        "assets/content.jsx-Pnj3N97b.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
