{
    "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "javascript": {
        "globals": [
            "chrome",
            "GM_info",
            "GM_getValue",
            "GM_setValue",
            "GM_deleteValue",
            "GM_listValues",
            "GM_addValueChangeListener",
            "GM_removeValueChangeListener",
            "GM_openInTab"
        ],
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "es5"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "files": {
        "includes": ["**", "!**/dist", "!**/node_modules", "!**/.local", "!**/.old", "!**/.tmp"]
    }
}
