{
    "manifest_version": 3,
    "name": "hypergravity",
    "version": "68",
    "description": "Enhance the Gemini web interface",
    "permissions": [
        "storage",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "*://gemini.google.com/*"
    ],
    "background": {
        "service_worker": "src/entry/background.ts"
    },
    "content_scripts": [
        {
            "matches": [
                "*://gemini.google.com/*"
            ],
            "js": [
                "src/entry/content.tsx"
            ]
        }
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "public/icons/icon16.png",
            "48": "public/icons/icon48.png",
            "128": "public/icons/icon128.png"
        }
    },
    "icons": {
        "16": "public/icons/icon16.png",
        "48": "public/icons/icon48.png",
        "128": "public/icons/icon128.png"
    }
}
