{
    "name": "hypergravity",
    "version": "71",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build:ext": "vite build",
        "build:user": "BUILD_TARGET=userscript vite build",
        "build:ext:release": "HG_STRIP_DEBUG=1 vite build --mode release",
        "build:user:release": "HG_STRIP_DEBUG=1 BUILD_TARGET=userscript vite build --mode release",
        "build:release": "bun run build:ext:release && bun run build:user:release",
        "typecheck": "tsc -p tsconfig.json",
        "typecheck:strict": "tsc -p tsconfig.strict.json",
        "lint": "biome lint .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "lint:imports": "node scripts/lint-import-aliases.mjs",
        "lint:architecture": "node scripts/lint-architecture-boundaries.mjs",
        "lint:architecture:strict": "HG_ARCH_FAIL=1 node scripts/lint-architecture-boundaries.mjs",
        "check": "bun run typecheck && bun run lint && bun run lint:imports && bun run lint:architecture && bun run build:ext && bun run build:user",
        "check:ci": "bun run typecheck && bun run lint && bun run lint:imports && bun run lint:architecture:strict && bun run build:ext && bun run build:user",
        "preview": "vite preview",
        "version:commits": "bun scripts/update-version-from-commits.mjs",
        "prepare": "bun scripts/setup-git-hooks.mjs"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",
        "@crxjs/vite-plugin": "latest",
        "@preact/preset-vite": "^2.10.3",
        "@types/chrome": "^0.1.29",
        "typescript": "^5.9.2",
        "vite": "^7.3.1",
        "vite-plugin-monkey": "^7.1.9"
    },
    "dependencies": {
        "docx": "^9.6.0",
        "idb": "^8.0.3",
        "jspdf": "^4.2.0",
        "preact": "^10.28.4",
        "rawproto": "^1.0.3",
        "sharp": "^0.34.5"
    }
}
