#!/usr/bin/env sh
set -eu

BUN_BIN="${BUN_BIN:-}"

if [ -z "$BUN_BIN" ]; then
    if command -v bun >/dev/null 2>&1; then
        BUN_BIN="$(command -v bun)"
    elif [ -x "$HOME/.bun/bin/bun" ]; then
        BUN_BIN="$HOME/.bun/bin/bun"
    else
        echo "bun is required for pre-push but was not found in PATH or at ~/.bun/bin/bun" >&2
        exit 127
    fi
fi

"$BUN_BIN" run typecheck
"$BUN_BIN" run lint
"$BUN_BIN" run lint:imports

"$BUN_BIN" scripts/update-version-from-commits.mjs

if git diff --quiet -- package.json manifest.json; then
    exit 0
fi

git commit --amend --no-edit --only -- package.json manifest.json

echo "Amended HEAD with version update. Re-run git push to include the amended commit." >&2
exit 1
